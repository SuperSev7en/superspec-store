# Supabase (storefront + admin auth + catalog)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only: Stripe webhooks write orders with this key (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe Checkout + webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test
STRIPE_SECRET_KEY=sk_live_or_test
# Dashboard → Developers → Webhooks → Signing secret for POST /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional site URL for emails/links
NEXT_PUBLIC_URL=https://your-domain.com

# Optional: forward /api/contact and /api/newsletter JSON to Zapier, Slack, etc.
CONTACT_WEBHOOK_URL=

# Production only: extra lock on /admin/* before Supabase login (HTTP Basic).
# If unset in production, middleware blocks admin routes (see middleware.ts).
ADMIN_BASIC_USER=
ADMIN_BASIC_PASSWORD=

# Optional: only these user UUIDs receive Expo push notifications from the Stripe webhook (comma-separated).
# Leave unset to notify every user with profiles.is_admin = true.
ADMIN_PUSH_USER_IDS=
