# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* at build time).
# Use the SAME Supabase project as your Next.js site (values from repo root `.env`).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Storefront base URL — “View store” / deep links
EXPO_PUBLIC_SITE_URL=https://superspec.studio

# EAS project ID (run `npx eas-cli init` in apps/admin-mobile, then paste here). Required for real Expo push tokens.
EAS_PROJECT_ID=

# Optional: only this email may sign in to the hub on this build (client-side).
EXPO_PUBLIC_ADMIN_LOCK_EMAIL=
